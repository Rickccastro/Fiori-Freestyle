<mvc:View controllerName="fiorifreestyle.controller.View1"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns:t="sap.ui.table"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <Button text="Hello" press="onPress" />

        <VBox class="sapUiTinyMargin">
            <Label text="Client Identification" />
            <Input />
        </VBox>

        <t:Table id="table1" rows="{/HeaderSet}" visibleRowCount="10" threshold="10" class="sapUiTinyMargin" selectionMode="MultiToggle">
            <t:toolbar>
                <OverflowToolbar>
                    <Title id="title" text="Ordens" />
                </OverflowToolbar>
            </t:toolbar>

            <t:columns>
                <t:Column width="4rem" sortProperty="OrderId">
                    <Label text="OrderId" />
                    <t:template>
                        <Text text="{OrderId}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="10rem" sortProperty="ClientID" filterProperty="ClientID" autoResizable="true">
                    <Label text="Client Identification" />
                    <t:template>
                        <Text text="{ClientID}" wrapping="false" />
                    </t:template>
                </t:Column>
                <t:Column width="10rem" sortProperty="TotalItems" filterProperty="TotalItems" autoResizable="true">
                    <Label text="Total Items" />
                    <t:template>
                        <Text text="{TotalItems}" wrapping="false" />
                    </t:template>
                </t:Column>
            </t:columns>
        </t:Table>
    </Page>
</mvc:View>
