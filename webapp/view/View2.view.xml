<mvc:View controllerName="fiorifreestyle.controller.View2"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns="sap.m">
    <Page id="page2" title="{i18n>title}">
      <VBox class="sapUiTinyMargin">
        <Label text="Model padrão da view (origem: controller)"/>
        <Text text="{/user/name}"/>

        <Text text="--------------------------------------------------"/>

        <Label text="Model 'dados' da view (origem: controller)"/>
        <Text text="{dados>/user/name}"/>

        <Text text="--------------------------------------------------"/>
        
        <Label text="Model i18n - chave title (origem: manifest)"/>
        <Text text="{i18n>title}"/>

        <Text text="--------------------------------------------------"/>

        <Label text="Model 'users' (origem: manifest)"/>
        <Text text="{usersInManifest>/0/id} - {usersInManifest>/0/name}"/>

        <Text text="--------------------------------------------------"/>
        
        <Label text="Model padrão do serviço (origem: manifest)"/>
        <List headerText="Order" items="{ path: '/HeaderSet' }" >
          <StandardListItem title="Ordem {OrderId}" description="{CreatedBy}"/>
        </List>

        <Text text="{/HeaderSet(1)/OrderId} - {/HeaderSet(1)/CreatedBy}"/>

        <Text text="--------------------------------------------------"/>

        <Button text="Testar Models" press="onTestModels"/>
      </VBox>
    </Page>
</mvc:View>