<mvc:View controllerName="fiorifreestyle.controller.FiltersPagesOrderPagination"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns="sap.m">
    <Page id="page6" title="{i18n>title}">

        <fb:FilterBar id="filterBar2" reset="onFilterReset" search="onFilterSearch">
		<fb:filterItems>
			<fb:FilterItem name="OrderId" label="{i18n>OrderId}">
				<fb:control>
					<Input value="{filter>/OrderId}"/>
				</fb:control>
			</fb:FilterItem>

			<fb:FilterItem name="ClientID" label="{i18n>ClientID}">
				<fb:control>
					<Input value="{filter>/ClientID}"/>
				</fb:control>
			</fb:FilterItem>

			<fb:FilterItem name="OrderField" label="{i18n>OrderField}">
				<fb:control>
					<Select selectedKey="{filter>/OrderField}">
						<items>
							<core:Item text="" key=""/>
							<core:Item text="{i18n>OrderId}" key="OrderId"/>
							<core:Item text="{i18n>ClientID}" key="ClientID"/>
							<core:Item text="{i18n>CreatedAt}" key="CreatedAt"/>
							<core:Item text="{i18n>CreatedBy}" key="CreatedBy"/>
							<core:Item text="{i18n>TotalItems}" key="TotalItems"/>
							<core:Item text="{i18n>TotalFreight}" key="TotalFreight"/>
							<core:Item text="{i18n>TotalOrder}" key="TotalOrder"/>
							<core:Item text="{i18n>Status}" key="Status"/>
						</items>
					</Select>
				</fb:control>
			</fb:FilterItem>

			<fb:FilterItem name="OrderType" label="{i18n>OrderType}">
				<fb:control>
					<Select selectedKey="{filter>/OrderType}">
						<items>
							<core:Item text="" key=""/>
							<core:Item text="{i18n>ASC}" key="ASC"/>
							<core:Item text="{i18n>DESC}" key="DESC"/>
						</items>
					</Select>
				</fb:control>
			</fb:FilterItem>

			<fb:FilterItem name="Limit" label="{i18n>Limit}">
				<fb:control>
					<Input value="{filter>/Limit}" type="Number"/>
				</fb:control>
			</fb:FilterItem>

			<fb:FilterItem name="Offset" label="{i18n>Offset}">
				<fb:control>
					<Input value="{filter>/Offset}" type="Number"/>
				</fb:control>
			</fb:FilterItem>

		</fb:filterItems>
	</fb:FilterBar>


	<t:Table id="table3"
		rows="{table>/}"
		selectionMode="MultiToggle"
		class="sapUiSmallMargin"
		rowMode="Fixed"
		threshold="10"
		visibleRowCount="10"
		enableBusyIndicator="true"
		>
		<t:toolbar>
			<OverflowToolbar>
				<Title id="title3" text="Orders"></Title>
			</OverflowToolbar>
		</t:toolbar>
		<t:columns>
			<t:Column width="100px" sortProperty="OrderId">
				<Label text="{i18n>OrderId}" />
				<t:template>
					<Text text="{table>OrderId}" wrapping="false" />
				</t:template>
			</t:Column>
			<t:Column width="100px" sortProperty="CreatedAt">
				<Label text="{i18n>CreatedAt}" />
				<t:template>
					<Text text="{path: 'table>CreatedAt', type: 'sap.ui.model.odata.type.Date', formatOptions: { UTC:true, pattern: 'dd/MM/yyyy'}}" wrapping="false" />
				</t:template>
			</t:Column>
			<t:Column width="100px" sortProperty="ClientID" filterProperty="ClientID" autoResizable="true">
				<Label text="{i18n>ClientID}" />
				<t:template>
					<Text text="{table>ClientID}" wrapping="false" />
				</t:template>
			</t:Column>
			<t:Column width="100px" sortProperty="CreatedBy" filterProperty="CreatedBy" autoResizable="true">
				<Label text="{i18n>CreatedBy}" />
				<t:template>
					<Text text="{table>CriadoPor}" wrapping="false" />
				</t:template>
			</t:Column>
			<t:Column width="100px" sortProperty="TotalItems" filterProperty="TotalItems" autoResizable="true">
				<Label text="{i18n>TotalItems}" />
				<t:template>
					<Text text="{table>TotalItems}" wrapping="false" />
				</t:template>
			</t:Column>
			<t:Column width="100px" sortProperty="TotalFreight" filterProperty="TotalFreight" autoResizable="true">
				<Label text="{i18n>TotalFreight}" />
				<t:template>
					<Text text="{table>TotalFreight}" wrapping="false" />
				</t:template>
			</t:Column>
			<t:Column width="100px" sortProperty="TotalOrder" filterProperty="TotalOrder" autoResizable="true">
				<Label text="{i18n>TotalOrder}" />
				<t:template>
					<Text text="{table>TotalOrder}" wrapping="false" />
				</t:template>
			</t:Column>
			<t:Column width="100px" sortProperty="Status" filterProperty="Status" autoResizable="true">
				<Label text="{i18n>Status}" />
				<t:template>
					<Text text="{path: 'table>Status', formatter: '.formatter.formatStatus'}" wrapping="false" />
				</t:template>
			</t:Column>
        </t:columns>
      </t:Table>

    </Page>
</mvc:View>