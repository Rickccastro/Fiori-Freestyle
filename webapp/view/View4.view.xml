<mvc:View controllerName="fiorifreestyle.controller.View4"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns:core="sap.ui.core"
    xmlns:t="sap.ui.table"
    xmlns="sap.m">
    <Page id="page4" title="{i18n>title}">
      <VBox class="sapUiTinyMargin">
        <Label text="Last Created Order"/>
        <Input id="lastOrdemId" editable="false"/>

        <TextArea id="textarea1" value="" rows="8" width="100%" editable="false"/>
      </VBox>
      <HBox class="sapUiTinyMargin">
        <Button text="Create Header" press="onCreateHeader"/>
        <Button text="Create Header (Deep)" press="onCreateDeepHeader"/>
        <Button text="Read Header" press="onReadHeader"/>
        <Button text="Update Header" press="onUpdateHeader"/>
        <Button text="Delete Header" press="onDeleteHeader"/>
      </HBox>
    </Page>
</mvc:View>